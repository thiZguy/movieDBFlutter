# Copiar este archivo a `.env` y completar con tu API key de TMDB.
# Obtener en: https://www.themoviedb.org/settings/api (registro gratuito)
# Usamos el v4 Read Access Token (Bearer), no la v3 API key.

TMDB_BEARER_TOKEN=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
